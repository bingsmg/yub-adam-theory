# Adam's Theory Stock Picker Configuration
# Copy to .env and customize

# Data paths
DATA_DIR=output/parquet
RESULTS_DIR=output/results
REPORTS_DIR=output/reports
ALL_STOCKS_PATH=output/all_stocks.parquet
STOCK_LIST_PATH=output/stock_list.csv

# Adam's Theory parameters
LOOKBACK_BARS=20
ADX_THRESHOLD=25.0
ER_MIN=0.3

# Detection thresholds
BREAKOUT_LOOKBACK=20
BREAKOUT_THRESHOLD_PCT=0.98
TREND_CHANGE_LOOKBACK=40
TREND_CHANGE_RECENT=15
RANGE_EXPANSION_MULTIPLE=1.5
GAP_MIN_PCT=0.5

# Filtering
MIN_PRICE=3.0
MAX_STOCKS_TO_ANALYZE=200

# Risk
MAX_RISK_SCORE=7.0
STOP_LOSS_ATR_MULTIPLE=2.0

# API
AKSHARE_DELAY_MIN=0.5
AKSHARE_DELAY_MAX=2.0
PARALLEL_WORKERS=4

# Reporting
TOP_N_RECOMMENDATIONS=20
