# Adam's Theory Stock Picker Configuration
# Copy to .env and customize

# Data paths
RESULTS_DIR=output/results
REPORTS_DIR=output/reports
ALL_STOCKS_PATH=output/all_stocks.parquet
STOCK_LIST_PATH=output/stock_list.csv

# ── Data source selection ──────────────────────────────────────
# Priority order: first available source wins (when strategy="priority")
# Available sources: akshare, baostock, efinance
DATA_SOURCE_ORDER=["akshare","baostock"]
DATA_SOURCE_STRATEGY=priority           # "priority" | "fastest_first"

# Fetch tuning
FETCH_DELAY_SECONDS=1.0                 # Min delay between requests (per thread)
FETCH_MAX_WORKERS=8                     # Parallel thread pool size
FETCH_RETRY_COUNT=3                     # Max retries per stock

# Adam's Theory parameters
LOOKBACK_BARS=20

# Detection thresholds
BREAKOUT_LOOKBACK=20
BREAKOUT_THRESHOLD_PCT=0.98
TREND_CHANGE_LOOKBACK=40
TREND_CHANGE_RECENT=15
RANGE_EXPANSION_MULTIPLE=1.5
GAP_MIN_PCT=0.5

# Filtering
MIN_PRICE=3.0
MAX_STOCKS_TO_ANALYZE=200

# Risk
MAX_RISK_SCORE=7.0

# Feishu (飞书) notification
FEISHU_WEBHOOK_URL=

# Reporting
TOP_N_RECOMMENDATIONS=20
