# Adam's Theory Stock Picker Configuration
# Copy to .env and customize for your environment
#
# All values shown are defaults. Lines can be omitted to use defaults.
# Boolean values: True / False (case insensitive)
# List values: ["item1","item2"] (JSON array syntax)

# ── Data paths ───────────────────────────────────────────────────────
RESULTS_DIR=output/results                 # Daily recommendation CSVs
REPORTS_DIR=output/reports                 # HTML reports with Plotly charts
ALL_STOCKS_PATH=output/all_stocks.parquet  # Legacy single-file store (backup)
DAILY_DIR=output/daily                     # Legacy date-partitioned store
STOCKS_DIR=output/stocks                   # Primary stock-partitioned store
STOCK_LIST_PATH=output/stock_list.csv      # Stock universe cache

# ── Data source selection ────────────────────────────────────────────
# Priority order: first available source wins (when strategy="priority")
# Available sources: tencent (Tencent API, recommended), akshare (EastMoney),
#                    baostock (own server, no rate limit), efinance
DATA_SOURCE_ORDER=["tencent","baostock"]
DATA_SOURCE_STRATEGY=priority              # "priority" | "fastest_first"

# Fetch tuning
FETCH_DELAY_SECONDS=1.0                    # Min delay between requests (per thread)
FETCH_MAX_WORKERS=1                        # Thread pool size (1 = sequential, safest)
FETCH_RETRY_COUNT=3                        # Max retries per stock

# ── Adam's Theory core parameters ────────────────────────────────────
LOOKBACK_BARS=20                           # Center symmetry projection lookback

# ── Detection thresholds ─────────────────────────────────────────────
BREAKOUT_LOOKBACK=20                       # Bars to consider for breakout high
TREND_CHANGE_LOOKBACK=40                   # Longer window for trend change detection
TREND_CHANGE_RECENT=15                     # Recent window for swing low/high
RANGE_EXPANSION_MULTIPLE=1.5               # Current range vs average range multiplier
GAP_MIN_PCT=0.5                            # Minimum gap % to qualify as range expansion

# ── Stock filtering (pre-screen) ─────────────────────────────────────
MIN_PRICE=3.0                              # Exclude penny stocks below this price (RMB)
MAX_STOCKS_TO_ANALYZE=5000                 # Pre-screen to top N candidates

# ── Board permissions ────────────────────────────────────────────────
# Set to True if you have trading permission for these boards.
# Main board (600-603,605, 000-003) is always allowed.
# ChiNext 创业板: 300,301xxx | STAR 科创板: 688,689xxx | BSE 北交所: 8/4xxxxx
ALLOW_CHINEXT=True
ALLOW_STAR_MARKET=True
ALLOW_BSE=False                            # Usually excluded

# ── Risk management ──────────────────────────────────────────────────
MAX_RISK_SCORE=7.0                         # Max acceptable risk score (1-10 scale)

# ── Scoring weights ──────────────────────────────────────────────────
# compute_quality_score weights: [condition_count, projection, volume]
SCORE_WEIGHTS=[0.50,0.30,0.20]

# ── Ranking (one-question rule thresholds) ───────────────────────────
RANK_KEEP_ALL_IF_LE=5                      # Keep all if <= this many signals
RANK_KEEP_FRAC_MID=0.8                     # Keep fraction when 6-15 signals
RANK_KEEP_FRAC_HIGH=0.7                    # Keep fraction when >15 signals
RANK_MID_THRESHOLD=15                      # Boundary between mid/high count
RANK_MIN_KEEP_MID=5                        # Minimum keep when mid count
RANK_MIN_KEEP_HIGH=10                      # Minimum keep when high count

# ── Feishu (飞书) notification ───────────────────────────────────────
# Get a webhook URL: Feishu → Group → Settings → Bots → Add Bot → Custom Bot
FEISHU_WEBHOOK_URL=

# ── WeChat Work (企业微信) notification ───────────────────────────────
# Get a webhook URL: 企业微信群 → 群设置 → 群机器人 → 添加机器人 → 复制 webhook URL
WECOM_WEBHOOK_URL=

# ── Reporting ────────────────────────────────────────────────────────
TOP_N_RECOMMENDATIONS=20                   # Number of recommendations to output
